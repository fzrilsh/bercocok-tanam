ROUTER_URL=https://vansrouter-production.up.railway.app/
CHROME_EXECUTABLE_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe
PW_HEADLESS=0
ACCOUNT_FILE=D:\Project\AutoCreate\accounts.txt
RESULT_FILE={provider}_keys.txt
ERROR_ACCOUNT_FILE=errorAccounts.txt
PROXY_POOL_FILE=proxy_pools.txt
BROWSER_COUNT=1
BROWSER_SLOW_MO=2
DELAY_BEFORE_NEXT_CLICK_MS=1000
DELAY_BETWEEN_ACCOUNTS_MS=3000
DELAY_BEFORE_BROWSER_CLOSE_MS=5000
DELAY_BEFORE_READING_COOKIES_MS=5000
TIMEOUT_NAVIGATION_MS=60000
TIMEOUT_DEFAULT_MS=15000
TIMEOUT_SHORT_MS=10000
BROWSER_ARGS_SETS=[["--disable-extensions","--disable-blink-features=AutomationControlled","--disable-features=BlockThirdPartyCookies","--disable-site-isolation-trials","--disable-web-security"],["--disable-extensions","--disable-blink-features=AutomationControlled","--disable-features=BlockThirdPartyCookies","--disable-site-isolation-trials","--disable-web-security"]]