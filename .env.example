# File paths for account management
ACCOUNT_FILE=accounts.txt
RESULT_FILE=output/keys/{provider}_keys.txt
ERROR_ACCOUNT_FILE=output/errors/errorAccounts.txt
PROXY_POOL_FILE=proxy_pools.txt

# Chrome/Chromium executable path
CHROME_EXECUTABLE_PATH=/path/to/Google Chrome

# Headless mode (1 = headless, 0 = with UI)
PW_HEADLESS=1

# Browser performance settings
BROWSER_COUNT=4
BROWSER_SLOW_MO=2

# Timing & delays (in milliseconds)
DELAY_BEFORE_NEXT_CLICK_MS=1000
DELAY_BETWEEN_ACCOUNTS_MS=3000
DELAY_BEFORE_BROWSER_CLOSE_MS=3000
DELAY_BEFORE_READING_COOKIES_MS=5000

# Timeout settings (in milliseconds)
TIMEOUT_NAVIGATION_MS=60000
TIMEOUT_DEFAULT_MS=15000
TIMEOUT_SHORT_MS=10000

# Browser launch arguments (JSON array of argument sets)
BROWSER_ARGS_SETS=[["--incognito","--disable-extensions","--disable-blink-features=AutomationControlled","--disable-features=BlockThirdPartyCookies","--disable-site-isolation-trials","--disable-web-security"],["--incognito","--disable-extensions","--disable-blink-features=AutomationControlled","--disable-features=BlockThirdPartyCookies","--disable-site-isolation-trials","--disable-web-security"]]

# 9Router configuration
# Base URL of your 9router instance
ROUTER_URL=http://127.0.0.1:20128/

# Password for 9router authentication
# If not set, accounts will be created but not auto-added to 9router
ROUTER_PASS=

# Temporary email provider selection
# Options: "auto" (random), "ncaori", "1secemail", "gmail", "mailcx"
# Array format: ["provider1","provider2"] will randomly select from specified providers
# Gmail provider uses plus-addressing (e.g. user+github000001@gmail.com) and reads OTP via Gmail API
TEMP_EMAIL_PROVIDER=auto

# Gmail provider configuration (required if using "gmail" provider)
# Path to Google OAuth credentials JSON (from console.cloud.google.com)
GMAIL_CREDENTIALS_FILE=creedentials.json

# Base Gmail address (plus-addresses will be generated from this)
GMAIL_BASE_ADDRESS=fazrilkopling@gmail.com

# Mail.cx provider configuration (required if using "mailcx" provider)
# API token from mail.cx dashboard (https://api.mail.cx)
MAIL_CX_API_TOKEN=

# Comma-separated domains for address generation
MAIL_CX_DOMAINS=@juned.run.place

# Account password configuration
# Default password for all account types (unless provider-specific password is set)
# For Grok: minimum 16 characters with letters+numbers required
PASSWORD=YourSecurePassword123!@#

# Grok-specific password (defaults to PASSWORD if not set)
GROK_PASSWORD=

# Turnstile extension configuration (required for Grok automation)
# Remote service URL for decrypting the encrypted turnstile extension
SEAL_UNLOCK_URL=https://wanglins.6n6.web.id

# Authentication token for the unlock service
SEAL_TOKEN=e4k-0Dil5dKU82VlBLzp50AdWmWVPCdc

# Optional: Local base64-encoded 32-byte AES-256-GCM key for decryption
# If set, SEAL_UNLOCK_URL is not needed
SEAL_KEY=

# Optional: Path to plain turnstile extension directory
# If set, encryption/decryption is bypassed (directory must contain script.js + manifest.json)
TURNSTILE_EXT_PATH=
